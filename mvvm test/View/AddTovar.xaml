<Window x:Class="mvvm_test.View.AddTovar"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:mvvm_test.View"
        mc:Ignorable="d"
        Title="AddTovar" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center " Orientation="Vertical">
            <TextBlock Text="Добавление товара" Style="{StaticResource PrimaryTextBlock}"/>

            <TextBlock Text="Название"/>
            <TextBox Style="{StaticResource PrimaryTextBox}"/>

            <TextBlock Text="Категория"/>
            <ComboBox Style="{StaticResource CmBox}"/>

            <TextBlock Text="Описание"/>
            <TextBox Style="{StaticResource PrimaryTextBox}"/>

            <TextBlock Text="Цена"/>
            <TextBox Text="сто минонов" Style="{StaticResource PrimaryTextBox}"/>

            <Button Content="Добавить" Style="{StaticResource AccentButtomStyle}"/>
        </StackPanel>
    </Grid>
</Window>
