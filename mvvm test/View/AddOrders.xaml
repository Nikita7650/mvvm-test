<Window x:Class="mvvm_test.View.AddOrders"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:mvvm_test.View"
        mc:Ignorable="d"
        Title="AddOrders" Height="450" Width="800">
    <Grid>
        <Border BorderBrush="Gray"
        BorderThickness="1"
        Margin="10">

            <StackPanel Orientation="Vertical"
                HorizontalAlignment="Center"
                Margin="10">

                <TextBlock Text="Добавление заказа"
                   Style="{StaticResource PrimaryTextBlock}"
                   Width="250"
                   Height="35"
                   FontSize="18"
                   Margin="5,15,5,20"/>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Клиент"
                       Style="{StaticResource PrimaryTextBlock}"
                       Width="150"/>
                    <ComboBox
                      Style="{StaticResource CmBox}"
                      Width="190">
                        <ComboBoxItem Content="Клиент 1"/>
                        <ComboBoxItem Content="Клиент 2"/>
                        <ComboBoxItem Content="Клиент 3"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Товар"
                       Style="{StaticResource PrimaryTextBlock}"
                       Width="150"/>
                    <ComboBox
                      Style="{StaticResource CmBox}"
                      Width="190">
                        <ComboBoxItem Content="Товар 1"/>
                        <ComboBoxItem Content="Товар 2"/>
                        <ComboBoxItem Content="Товар 3"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Количество"
                       Style="{StaticResource PrimaryTextBlock}"
                       Width="150"/>
                    <TextBox
                     Text=""
                     Style="{StaticResource PrimaryTextBox}"
                     Width="190"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Дата заказа"
                       Style="{StaticResource PrimaryTextBlock}"
                       Width="150"/>
                    <DatePicker
                        Width="190"
                        Height="30"
                        Margin="5"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Статус"
                       Style="{StaticResource PrimaryTextBlock}"
                       Width="150"/>
                    <ComboBox
                      Style="{StaticResource CmBox}"
                      Width="190">
                        <ComboBoxItem Content="Новый"/>
                        <ComboBoxItem Content="В обработке"/>
                        <ComboBoxItem Content="Завершён"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Комментарий"
                       Style="{StaticResource PrimaryTextBlock}"
                       Width="150"/>
                    <TextBox
                     Text=""
                     Style="{StaticResource PrimaryTextBox}"
                     Width="190"
                     Height="60"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"/>
                </StackPanel>

                <Button
                Content="Добавить"
                Style="{StaticResource AccentButtomStyle}"
                Margin="5,25,5,5"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
